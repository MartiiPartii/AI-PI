# Environment for the AI-PI website. Copy to `.env` and fill in real values.

# --- Database ---
# Postgres connection string. Local demo uses Docker:
#   docker run -d --name aipi-postgres -e POSTGRES_USER=aipi \
#     -e POSTGRES_PASSWORD=aipi -e POSTGRES_DB=aipi -p 5432:5432 postgres:16
DATABASE_URL="postgresql://aipi:aipi@localhost:5432/aipi?schema=public"

# --- Session ---
# Secret used to sign the session JWT (HS256). At least 32 chars; random in prod.
# Generate: `openssl rand -base64 48`
SESSION_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# --- Internal service auth ---
# Shared secret the telephony service must present (x-internal-secret) to POST
# scored results to /api/results. MUST match the telephony service's value.
INTERNAL_API_SECRET="change-me-shared-with-telephony-service"

# --- AI model service (FastAPI) ---
# Called server-side only; never exposed to the browser.
FASTAPI_URL="http://localhost:8000"

# --- Phone line (landing-page CTAs) ---
PHONE_NUMBER=+359700XXXXX
PHONE_NUMBER_DISPLAY=+359 700 XX XXX
