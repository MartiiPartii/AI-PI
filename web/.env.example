# Screening phone line shown in the landing page CTAs.
#
# PHONE_NUMBER is the dialable E.164 value used in `tel:` links.
# PHONE_NUMBER_DISPLAY is the pretty, human-readable form shown on screen
# (optional — falls back to PHONE_NUMBER when unset).
#
# Read on the server only (no NEXT_PUBLIC_ prefix), so it is baked into the
# rendered HTML and the call-to-action works without client-side JavaScript.
PHONE_NUMBER=+359700XXXXX
PHONE_NUMBER_DISPLAY=+359 700 XX XXX
