# Port the HTTP server listens on
PORT=3000

# Twilio account SID (Twilio Console > Account Info).
# Used by the REST client to end (hang up) calls.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio account auth token (Twilio Console > Account Info).
# Used to validate that incoming webhooks really came from Twilio, and for the REST client.
TWILIO_AUTH_TOKEN=your_auth_token_here

# Public HTTPS base URL Twilio uses to reach this service, e.g. your ngrok URL.
# No trailing slash. Must match the webhook URL configured on your number.
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# Set to "true" to skip signature validation for local curl testing only.
# Never enable this in production.
SKIP_WEBHOOK_VALIDATION=false

# OpenAI API key for the GPT Realtime speech-to-speech conversation.
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the Realtime model, voice, agent instructions, or greeting.
OPENAI_REALTIME_MODEL=gpt-realtime
AGENT_VOICE=alloy
# AGENT_INSTRUCTIONS=...
# AGENT_GREETING=...

# Optional: phone number (E.164) the result SMS is sent from.
# If unset, the number the caller dialled is used as the sender.
# TWILIO_SMS_FROM=+1234567890

# Base URL of the FastAPI model service that scores the voice sample.
# Currently mocked in code, so this value is not yet used.
FASTAPI_URL=http://localhost:8000

# How long (ms) to record the caller's sustained "ahhh" after the beep.
CAPTURE_DURATION_MS=5000
