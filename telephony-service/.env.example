# Port the HTTP server listens on
PORT=3000

# Twilio account auth token (Twilio Console > Account Info).
# Used to validate that incoming webhooks really came from Twilio.
TWILIO_AUTH_TOKEN=your_auth_token_here

# Public HTTPS base URL Twilio uses to reach this service, e.g. your ngrok URL.
# No trailing slash. Must match the webhook URL configured on your number.
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# Set to "true" to skip signature validation for local curl testing only.
# Never enable this in production.
SKIP_WEBHOOK_VALIDATION=false
